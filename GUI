import pygame
pygame.init()
pygame.font.init()
pygame.display.set_caption("BlackJack")


scrn = pygame.display.set_mode((600, 800))
pygame.image.load("BlackJack_Table.jpg")
scrn.fill((37, 64, 85))
scrn.blit(pygame.image.load("BlackJack_Table.jpg"), (0, 200))
pygame.display.flip()
running = True
while running:
    for event in pygame.event.get():
        pygame.display.update()
        if event.type == pygame.QUIT:
            running = False
