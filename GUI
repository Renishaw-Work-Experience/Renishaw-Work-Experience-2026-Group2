import pygame
pygame.init()
pygame.font.init()
pygame.display.set_caption("BlackJack")


scrn = pygame.display.set_mode((600, 800))
table_img = pygame.image.load("BlackJack_Table.jpg")
#dealer_img = pygame.image.load("black dealer v2.webp").convert_alpha()
#dealer_img = pygame.transform.scale(dealer_img, (int(dealer_img.get_width() * 0.5), int(dealer_img.get_height() * 0.5)))
run = True
hitButton = pygame.image.load("hitbuttonred.png").convert_alpha()
standButton = pygame.image.load("standbuttonred.png").convert_alpha()
blankCard = pygame.image.load("blank card.jpg").convert_alpha()
blankCard = pygame.transform.scale(blankCard, (int(blankCard.get_width() * 0.2), int(blankCard.get_height() * 0.2)))
#dealer_img = pygame.transform.scale(dealer_img, (int(dealer_img.get_width() * 0.8), int(dealer_img.get_height() * 0.8))) 
Player2HitCount = 2
PlayerHitCount = 2

class Button:
    def __init__(self, x, y, image, scale, button_type):
        
        self.image = pygame.transform.scale(image, (int(image.get_width() * scale), int(image.get_height() * scale)))
        self.rect = self.image.get_rect()
        self.rect.topleft = (x, y)
        self.clicked = False
        self.button_type = button_type

    def draw(self):
        global PlayerHitCount
        global Player2HitCount
        action = False
        # get mouse position
        pos = pygame.mouse.get_pos()

        # check mouseover and clicked conditions
        if self.rect.collidepoint(pos):
            if pygame.mouse.get_pressed()[0] == 1 and not self.clicked:               
                if self.button_type == "hit":
                    self.clicked = True
                    action = True
                    if PlayerHitCount < 5:
                        PlayerHitCount += 1
                    else:
                        pass
                    return PlayerHitCount
                elif self.button_type == "stand":
                    self.clicked = True
                    action = True

        if pygame.mouse.get_pressed()[0] == 0:
            self.clicked = False

        # draw button on screen
        scrn.blit(self.image, (self.rect.x, self.rect.y))

        return action

def draw_text(text, font_size, color, x, y):
    font = pygame.font.SysFont(None, font_size)
    text_surface = font.render(text, True, color)
    scrn.blit(text_surface, (x, y))

hit_button = Button(50, 600, hitButton, 0.2, "hit")
stand_button = Button(450, 600, standButton, 0.2, "stand" )

while run:
    scrn.fill((37, 64, 85))
    scrn.blit(table_img, (0, 200))
    
    for i in range(Player2HitCount):
        x = 0 + i * 50
        scrn.blit(blankCard, (x, 425))
    for i in range(PlayerHitCount):
        x = 350 + i * 50
        scrn.blit(blankCard, (x, 425))

    for event in pygame.event.get():    
        if event.type == pygame.QUIT:
            run = False
    hit_button.draw()
    stand_button.draw()
    draw_text("""Player bet: 3
    Total: 7""", 50, (255, 255, 255), 200, 600)
    pygame.display.update()    